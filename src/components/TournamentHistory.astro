---
import type { MtgEloEvent } from "../lib/api/mtgelo";
import type { MeleeResult } from "../lib/api/meleegg";

interface Props {
  eloEvents: MtgEloEvent[];
  meleeResults: MeleeResult[];
}

const { eloEvents, meleeResults } = Astro.props;

interface UnifiedEvent {
  name: string;
  date: string;
  format: string;
  record: string;
  rank: string;
  deckName: string;
  deckUrl: string | null;
  tournamentUrl: string | null;
  source: "elo" | "melee" | "both";
}

function simplifyName(name: string): string {
  let s = name;
  // Strip bracketed prefixes like "[Lyon Sat 09:00]"
  s = s.replace(/^\[.*?\]\s*/i, "");
  // Strip "Ultimate Guard " prefix
  s = s.replace(/^Ultimate Guard\s+/i, "");
  // Strip "European Magic Series " prefix
  s = s.replace(/^European Magic Series\s*-?\s*/i, "");
  // Simplify "Regional Championship N - City" → "Regional Championship City"
  s = s.replace(/Regional Championship\s*\d*\s*-\s*/i, "Regional Championship ");
  // Strip "Magic Spotlight Series - " prefix
  s = s.replace(/^Magic Spotlight Series\s*-\s*/i, "");
  // Strip "Standard Open - " prefix
  s = s.replace(/^Standard Open\s*-\s*/i, "Open ");
  // Strip trailing year (e.g. " 2025", " 2026")
  s = s.replace(/\s+\d{4}$/, "");
  // Clean up double spaces
  s = s.replace(/\s+/g, " ").trim();
  return s;
}

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString("en-US", { month: "short", year: "numeric" });
}

// Index melee results by normalized name + month for matching
function normalizeForMatch(name: string): string {
  return name
    .toLowerCase()
    .replace(/\d{4}/g, "")
    .replace(/[^a-z ]/g, "")
    .trim()
    .replace(/\s+/g, " ");
}

function monthKey(dateStr: string): string {
  const d = new Date(dateStr);
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
}

function deckUrl(r: MeleeResult): string | null {
  if (r.DecklistGuid) return `https://melee.gg/Decklist/View/${r.DecklistGuid}`;
  if (r.DecklistId) return `https://melee.gg/Decklist/View/${r.DecklistId}`;
  return null;
}

const meleeByKey = new Map<string, MeleeResult>();
for (const r of meleeResults) {
  const key = `${normalizeForMatch(r.TournamentName)}|${monthKey(r.TournamentStartDate)}`;
  meleeByKey.set(key, r);
}

const usedMeleeKeys = new Set<string>();
const unified: UnifiedEvent[] = [];

for (const event of eloEvents) {
  const key = `${normalizeForMatch(event.name)}|${monthKey(event.date)}`;
  const meleeMatch = meleeByKey.get(key);

  if (meleeMatch) {
    usedMeleeKeys.add(key);
    unified.push({
      name: event.name,
      date: event.date,
      format: meleeMatch.FormatDescription || meleeMatch.Format || event.format || "",
      record: meleeMatch.Record !== "-" ? meleeMatch.Record : "",
      rank: meleeMatch.Rank > 0 ? `#${meleeMatch.Rank}` : "",
      deckName: meleeMatch.DecklistName && meleeMatch.DecklistName !== "Decklist" ? meleeMatch.DecklistName : "",
      deckUrl: deckUrl(meleeMatch),
      tournamentUrl: `https://melee.gg/Tournament/View/${meleeMatch.TournamentId}`,
      source: "both",
    });
  } else {
    unified.push({
      name: event.name,
      date: event.date,
      format: event.format || "",
      record: "",
      rank: "",
      deckName: "",
      deckUrl: null,
      tournamentUrl: event.code ? `https://mtgeloproject.net/events/${event.code}` : null,
      source: "elo",
    });
  }
}

for (const [key, r] of meleeByKey) {
  if (usedMeleeKeys.has(key)) continue;
  const date = r.TournamentStartDate.split("T")[0];
  unified.push({
    name: r.TournamentName,
    date,
    format: r.FormatDescription || r.Format || "",
    record: r.Record !== "-" ? r.Record : "",
    rank: r.Rank > 0 ? `#${r.Rank}` : "",
    deckName: r.DecklistName && r.DecklistName !== "Decklist" ? r.DecklistName : "",
    deckUrl: deckUrl(r),
    tournamentUrl: `https://melee.gg/Tournament/View/${r.TournamentId}`,
    source: "melee",
  });
}

unified.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

{unified.length > 0 ? (
  <ul class="history">
    {unified.map((event) => (
      <li class="event">
        <div class="event-main">
          {event.tournamentUrl ? (
            <a href={event.tournamentUrl} target="_blank" rel="noopener noreferrer" class="event-name event-link">{simplifyName(event.name)}, {formatDate(event.date)}</a>
          ) : (
            <span class="event-name">{simplifyName(event.name)}, {formatDate(event.date)}</span>
          )}
        </div>
        <div class="event-details">
          {event.record && <span><span class="label">Record</span> {event.record}</span>}
          {event.rank && <span><span class="label">Finish</span> {event.rank}</span>}
          {event.deckName && (
            event.deckUrl ? (
              <span><span class="label">Deck</span> <a href={event.deckUrl} target="_blank" rel="noopener noreferrer" class="deck-link">{event.deckName}</a></span>
            ) : (
              <span><span class="label">Deck</span> {event.deckName}</span>
            )
          )}
        </div>
      </li>
    ))}
  </ul>
) : (
  <p class="no-data">No tournament history available.</p>
)}

<style>
  .history {
    list-style: none;
    padding: 0;
  }

  .event {
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--color-rule);
  }

  .event:first-child {
    border-top: 1px solid var(--color-rule);
  }

  .event-main {
    display: flex;
    align-items: baseline;
  }

  .event-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    line-height: 1.3;
  }

  .event-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }

  .event-link:hover {
    color: var(--color-accent);
  }

  .event-details {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem var(--space-md);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: 0.15rem;
  }

  .label {
    opacity: 0.55;
    margin-right: 0.15rem;
  }

  .deck-link {
    color: var(--color-accent);
    transition: opacity 0.15s;
  }

  .deck-link:hover {
    opacity: 0.7;
  }

  .no-data {
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
