---
import Base from "../../layouts/Base.astro";
import TournamentHistory from "../../components/TournamentHistory.astro";
import { getCollection } from "astro:content";
import { loadPlayerData } from "../../lib/api/cached-data";

export async function getStaticPaths() {
  const players = await getCollection("players");
  return players.map((player) => ({
    params: { id: player.id },
    props: { player },
  }));
}

const { player } = Astro.props;
const { name, location, mtgelo } = player.data;

const tournamentData = loadPlayerData(player.id);
const profile = tournamentData.elo.profile;
const eloUrl = mtgelo ? `https://mtgeloproject.net/profile/${mtgelo}` : null;
---

<Base title={name}>
  <article class="player">
    <h1>{name}</h1>
    <p class="location">{location}</p>

    {profile && (
      <p class="rating">
        <span class="rating-label">Elo:</span>
        {eloUrl ? (
          <a href={eloUrl} target="_blank" rel="noopener noreferrer">
            {Math.round(profile.current_rating)}
          </a>
        ) : (
          Math.round(profile.current_rating)
        )}
      </p>
    )}

    <section class="tournaments">
      <TournamentHistory
        eloEvents={tournamentData.elo.events}
        meleeResults={tournamentData.melee}
      />
    </section>

    <a href="/" class="back">&larr; Back</a>
  </article>
</Base>

<style>
  .player {
    padding: var(--space-sm) 0 var(--space-xl);
  }

  h1 {
    font-size: 2.2rem;
    margin-bottom: 0.1rem;
  }

  .location {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: var(--space-lg);
  }

  .rating {
    font-size: 2rem;
    font-weight: 500;
    margin-bottom: var(--space-xl);
    line-height: 1;
  }

  .rating a {
    color: var(--color-accent);
    transition: opacity 0.15s;
  }

  .rating a:hover {
    opacity: 0.7;
  }

  .rating-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-right: 0.3rem;
    font-weight: 400;
  }

  .tournaments {
    margin-bottom: var(--space-xl);
  }

  .back {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    transition: color 0.15s;
  }

  .back:hover {
    color: var(--color-text);
  }
</style>
